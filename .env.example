# ============================================================
# AirLynk — Environment Configuration Template
# ============================================================
# Copy this file to .env.development and fill in the values.
# NEVER commit real secrets to version control.
# ============================================================

# --- Application ---
APP_NAME=airlynk
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=DEBUG

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://airlynk:airlynk_secret@postgres:5432/airlynk
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- RabbitMQ ---
RABBITMQ_URL=amqp://airlynk:airlynk_secret@rabbitmq:5672/

# --- JWT ---
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_AT_LEAST_32_CHARACTERS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- SMTP ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@airlynk.dev

# --- OpenTelemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=airlynk-api

# --- AWS (production only) ---
AWS_REGION=us-east-1
