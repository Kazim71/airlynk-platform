{
  "title": "AirLynk - Celery Workers",
  "uid": "celery-workers",
  "tags": ["airlynk", "celery"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 36,
  "panels": [
    {
      "title": "Task Duration (p95)",
      "type": "timeseries",
