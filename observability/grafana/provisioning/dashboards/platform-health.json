{
  "title": "AirLynk Platform Health",
  "uid": "platform-health",
  "tags": ["airlynk", "platform", "health"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 36,
  "panels": [
    {
      "title": "Active WebSocket Connections",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (domain) (airlynk_websocket_active_connections)",
          "legendFormat": "{{domain}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "RabbitMQ Messages Published",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(airlynk_rabbitmq_messages_published_total[1m])",
          "legendFormat": "{{routing_key}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "RabbitMQ Messages Consumed",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(airlynk_rabbitmq_messages_consumed_total[1m])",
          "legendFormat": "{{queue_name}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "title": "HTTP 5xx Errors",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(airlynk_http_errors_total[1m])",
          "legendFormat": "{{method}} {{path}}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ]
}
